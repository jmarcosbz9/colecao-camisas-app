import { createRouter, createWebHistory } from 'vue-router';
import type { RouteRecordRaw } from 'vue-router';

import Home from '@/views/Home.vue';
import FlamengoGrid from '@/views/FlamengoGrid.vue';
import OutrosTimesGrid from '@/views/OutrosTimesGrid.vue';

const routes: RouteRecordRaw[] = [
  { path: '/', name: 'home', component: Home },
  { path: '/flamengo', name: 'flamengo', component: FlamengoGrid },
  { path: '/outros_times', name: 'outros', component: OutrosTimesGrid },
];

const router = createRouter({
  history: createWebHistory(),
  routes,
});

export default router;
